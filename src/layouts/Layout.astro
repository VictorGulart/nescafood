---
import 'aos/dist/aos.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Nescafood — home-cooked meals, made to order.' } = Astro.props;

const WHATSAPP_NUMBER = '11234567890'; // TODO: replace with the real WhatsApp number, digits only, country code first
const WHATSAPP_MESSAGE = encodeURIComponent("Hi Nescafood! I'd like to get a quote for an order.");
const waHref = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MESSAGE}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E🍲%3C/text%3E%3C/svg%3E" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,500;1,9..144,600&family=Work+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-40 bg-ink/90 backdrop-blur border-b border-paper/10">
      <nav class="max-w-6xl mx-auto flex items-center justify-between px-5 py-4">
        <a href="/" class="font-display italic text-2xl text-paper tracking-tight">Nescafood</a>
        <div class="flex items-center gap-6 font-mono text-xs uppercase tracking-widest">
          <a href="/" class="text-paper/80 hover:text-mustard transition-colors">Home</a>
          <a href="/products" class="text-paper/80 hover:text-mustard transition-colors">Menu</a>
          <a href={waHref} target="_blank" rel="noopener" class="hidden sm:inline-flex items-center gap-2 bg-chili hover:bg-chili-dark text-paper px-4 py-2 rounded-full transition-colors">
            Get a quote
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-paper/10 mt-20">
      <div class="max-w-6xl mx-auto px-5 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 font-mono text-xs text-paper/60 uppercase tracking-widest">
        <p>&copy; {new Date().getFullYear()} Nescafood — made fresh, made local.</p>
        <a href={waHref} target="_blank" rel="noopener" class="text-mustard hover:text-paper transition-colors">Message us on WhatsApp →</a>
      </div>
    </footer>

    <a
      href={waHref}
      target="_blank"
      rel="noopener"
      aria-label="Get a quote on WhatsApp"
      class="sm:hidden fixed bottom-5 right-5 z-50 bg-chili text-paper w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-black/40"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7"><path d="M12.04 2c-5.5 0-9.96 4.46-9.96 9.96 0 1.76.46 3.45 1.33 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.5 0 9.96-4.46 9.96-9.96S17.54 2 12.04 2Zm5.83 14.24c-.25.7-1.24 1.28-2.02 1.45-.54.11-1.24.2-3.6-.77-3.02-1.25-4.96-4.3-5.11-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.05-2.49.25-.28.6-.4.94-.4.11 0 .21 0 .3.01.27.01.4-.02.62.47.25.6.86 2.06.94 2.21.08.15.13.32.03.52-.1.2-.15.32-.3.49-.15.18-.31.4-.44.53-.15.15-.3.31-.13.6.17.29.77 1.28 1.65 2.08 1.14 1.02 2.1 1.34 2.39 1.49.29.15.46.13.63-.07.17-.2.72-.84.91-1.13.19-.29.38-.24.63-.14.25.1 1.6.75 1.87.89.27.14.46.2.53.32.06.12.06.7-.19 1.4Z"/></svg>
    </a>

    <script>
      import AOS from 'aos';
      AOS.init({ duration: 700, once: true, offset: 40, easing: 'ease-out-quart' });
    </script>
  </body>
</html>
