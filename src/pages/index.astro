---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';
import home from '../data/home.json';
import settings from '../data/settings.json';

const allProducts = await getCollection('products');
const featured = allProducts.slice(0, 3);

const waHref = `https://wa.me/${settings.whatsappNumber}?text=${encodeURIComponent(settings.whatsappMessage)}`;
---

<Layout title="Nescafood — Home-cooked meals, made to order">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={home.heroImage}
        alt=""
        class="w-full h-full object-cover opacity-30"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/40 via-ink to-ink"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-5 pt-20 pb-28 sm:pt-28 sm:pb-36">
      <span
        class="inline-block font-mono text-xs uppercase tracking-widest text-mustard border border-mustard/40 rounded-full px-3 py-1 mb-6"
        data-aos="fade-down"
      >
        {home.heroBadge}
      </span>

      <h1
        class="font-display text-5xl sm:text-7xl leading-[1.05] text-paper max-w-3xl"
        data-aos="fade-up"
      >
        {home.heroHeadingBefore}<em class="text-chili not-italic">{home.heroHeadingEmphasis}</em>{home.heroHeadingAfter}
      </h1>

      <p class="mt-6 max-w-xl text-paper/70 text-lg" data-aos="fade-up" data-aos-delay="100">
        {home.heroDescription}
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4" data-aos="fade-up" data-aos-delay="200">
        <a
          href={waHref}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 bg-chili hover:bg-chili-dark text-paper font-medium px-6 py-3 rounded-full transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12.04 2c-5.5 0-9.96 4.46-9.96 9.96 0 1.76.46 3.45 1.33 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.5 0 9.96-4.46 9.96-9.96S17.54 2 12.04 2Zm5.83 14.24c-.25.7-1.24 1.28-2.02 1.45-.54.11-1.24.2-3.6-.77-3.02-1.25-4.96-4.3-5.11-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.05-2.49.25-.28.6-.4.94-.4.11 0 .21 0 .3.01.27.01.4-.02.62.47.25.6.86 2.06.94 2.21.08.15.13.32.03.52-.1.2-.15.32-.3.49-.15.18-.31.4-.44.53-.15.15-.3.31-.13.6.17.29.77 1.28 1.65 2.08 1.14 1.02 2.1 1.34 2.39 1.49.29.15.46.13.63-.07.17-.2.72-.84.91-1.13.19-.29.38-.24.63-.14.25.1 1.6.75 1.87.89.27.14.46.2.53.32.06.12.06.7-.19 1.4Z"/></svg>
          {home.primaryCtaLabel}
        </a>
        <a href="/products" class="font-mono text-xs uppercase tracking-widest text-paper/80 hover:text-mustard transition-colors underline underline-offset-4">
          {home.secondaryCtaLabel}
        </a>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="max-w-6xl mx-auto px-5 py-20 grid sm:grid-cols-3 gap-8">
    {home.whyUs.map((item, i) => (
      <div data-aos="fade-up" data-aos-delay={i * 100} class="border-t border-paper/15 pt-5">
        <span class="font-mono text-xs text-mustard">0{i + 1}</span>
        <h3 class="font-display italic text-2xl text-paper mt-2 mb-2">{item.title}</h3>
        <p class="text-paper/65 text-sm leading-relaxed">{item.body}</p>
      </div>
    ))}
  </section>

  <!-- Featured products -->
  <section class="max-w-6xl mx-auto px-5 pb-24">
    <div class="flex items-end justify-between mb-10" data-aos="fade-up">
      <div>
        <span class="font-mono text-xs uppercase tracking-widest text-mustard">{home.menuEyebrow}</span>
        <h2 class="font-display italic text-4xl text-paper mt-2">{home.menuHeading}</h2>
      </div>
      <a href="/products" class="hidden sm:inline font-mono text-xs uppercase tracking-widest text-paper/70 hover:text-mustard transition-colors">
        {home.menuLinkLabel}
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((product, i) => (
        <ProductCard
          title={product.data.title}
          description={product.data.description}
          price={product.data.price}
          image={product.data.image}
          tag={product.data.tag}
          delay={i * 100}
        />
      ))}
    </div>
  </section>

  <!-- CTA band -->
  <section class="border-t border-paper/10">
    <div class="max-w-6xl mx-auto px-5 py-20 text-center" data-aos="zoom-in">
      <h2 class="font-display italic text-4xl sm:text-5xl text-paper max-w-2xl mx-auto">
        {home.ctaHeading}
      </h2>
      <p class="mt-4 text-paper/65">{home.ctaBody}</p>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="mt-8 inline-flex items-center gap-3 bg-chili hover:bg-chili-dark text-paper font-medium px-7 py-4 rounded-full transition-colors"
      >
        {home.ctaButtonLabel}
      </a>
    </div>
  </section>
</Layout>
