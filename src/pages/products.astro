---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
---

<Layout title="Menu — Nescafood" description="Everything Nescafood cooks, made to order.">
  <section class="max-w-6xl mx-auto px-5 pt-16 pb-10">
    <span class="font-mono text-xs uppercase tracking-widest text-mustard" data-aos="fade-down">
      The full menu
    </span>
    <h1 class="font-display italic text-5xl sm:text-6xl text-paper mt-3 max-w-2xl" data-aos="fade-up">
      Everything's made when you order it.
    </h1>
    <p class="mt-4 text-paper/65 max-w-xl" data-aos="fade-up" data-aos-delay="100">
      Browse the menu, then message us on WhatsApp with what you'd like and how many people
      you're feeding — we'll send a quote back the same day.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 pb-24">
    {products.length === 0 ? (
      <p class="text-paper/60 font-mono text-sm">No dishes yet — add one from the CMS at /admin.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product, i) => (
          <ProductCard
            title={product.data.title}
            description={product.data.description}
            price={product.data.price}
            image={product.data.image}
            tag={product.data.tag}
            delay={(i % 3) * 100}
          />
        ))}
      </div>
    )}
  </section>
</Layout>
